  "query": "\n        SELECT \n            origin_uid as \"origin!:_\",\n            logs as \"text!:_\",\n            severity as \"severity:_\",\n            created_at as \"created_at!:_\"\n        FROM logs \n        WHERE origin_uid = $1 \n        ORDER BY created_at DESC \n        LIMIT $2\n        ",
